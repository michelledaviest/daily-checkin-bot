# Healthchecks.io ping URLs (full https://hc-ping.com/<uuid>)
HC_HEARTBEAT_URL=
HC_DAILY_URL=

# Optional overrides
BOT_NAME=June
MORNING_HOUR=9
EVENING_HOUR=19
TIMEZONE=America/New_York
STATE_DIR=./state
LOGS_DIR=./logs
MAX_TURNS=8
