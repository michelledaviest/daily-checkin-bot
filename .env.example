# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# Gemini (Google AI Studio API key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Sheets
GSA_KEY_PATH=/opt/checkin/gsa-key.json
SHEET_ID=
SHEET_TAB=checkins
ENVIRONMENT_TAB=environment

# Healthchecks.io ping URLs (full https://hc-ping.com/<uuid>)
HC_HEARTBEAT_URL=
HC_DAILY_URL=

# Optional overrides
BOT_NAME=June
MORNING_HOUR=9
EVENING_HOUR=19
HYDRATION_NUDGE_HOURS=11,14,17
TIMEZONE=America/New_York
STATE_DIR=./state
LOGS_DIR=./logs
MAX_TURNS=8

# Habit goals
WATER_GOAL_OZ=60
SLEEP_GOAL_HOURS=7
STEPS_GOAL=10000
EXERCISE_WEEKLY_GOAL_MIN=150

# Barometric pressure (Open-Meteo, no API key needed)
LATITUDE=42.36
LONGITUDE=-71.06

# Laptop screen time via ActivityWatch — set to true once screen_logger is installed.
# See docs/activitywatch-setup.md for setup instructions.
TRACK_SCREEN_TIME=false
