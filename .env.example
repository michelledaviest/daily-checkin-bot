# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# Gemini (Google AI Studio API key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Sheets
GSA_KEY_PATH=/opt/checkin/gsa-key.json
SHEET_ID=
